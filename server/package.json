{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "build": "echo 'Server uses native ESM — no build step required'",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --forceExit",
    "test:watch": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --watch",
    "lint": "echo 'No ESLint configured for server — add eslint if needed'",
    "verify": "node scripts/verify-deployment.mjs"
  },
  "dependencies": {
    "@ibm-cloud/watsonx-ai": "^1.7.14",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ibm-cos-sdk": "^1.15.1",
    "image-size": "^2.0.2",
    "mongodb": "^7.4.0",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/*.test.js"
    ]
  }
}
