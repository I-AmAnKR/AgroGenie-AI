PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# AI Provider mode
# true  = use mock AI responses (safe for demo, no IBM credentials required)
# false = use real IBM Granite via watsonx.ai (requires WATSONX_* vars below)
USE_MOCK_PROVIDERS=true

# ── Step 17: Demo Mode ────────────────────────────────────────────────────────
# When true, seeds sample data (farmer, farm, conversations) automatically.
# All AI responses are tagged isDemo:true and a banner is shown in the UI.
# Ideal for conference demos and SkillsBuild presentations.
# Set USE_MOCK_PROVIDERS=true alongside this for a fully credential-free demo.
ENABLE_DEMO_MODE=false

# ── Phase 17A: Production Hardening ──────────────────────────────────────────

# Log level override: error | warn | info | debug
# Defaults to 'debug' in development and 'info' in production.
# In production, log output is newline-delimited JSON for log aggregators.
LOG_LEVEL=

# Extra trusted CORS origins beyond CLIENT_URL (comma-separated).
# Example: CORS_EXTRA_ORIGINS=https://app.agrogenie.in,https://admin.agrogenie.in
CORS_EXTRA_ORIGINS=

# Rate limit sliding window in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window in production (default: 200)
RATE_LIMIT_MAX_PROD=200

# Maximum requests per window in development (default: 1000)
RATE_LIMIT_MAX_DEV=1000

# ── IBM watsonx.ai (Phase 6) ────────────────────────────────────────────────
# Required when USE_MOCK_PROVIDERS=false
# How to find your Project ID: IBM Cloud → watsonx.ai → Manage → Projects
# Regional URL: https://us-south.ml.cloud.ibm.com (us-south) or relevant region
# Model ID: e.g. ibm/granite-3-8b-instruct or ibm/granite-13b-chat-v2
# Get API key: IBM Cloud → Manage → Access (IAM) → API keys
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ── MongoDB Atlas (Phase 5) ──────────────────────────────────────────────────
# Connection string from Atlas: Database → Connect → Drivers
MONGODB_URI=
MONGODB_DB_NAME=agrogenie

# ── IBM Cloud Object Storage (Phase 7) ───────────────────────────────────────
# Required when USE_MOCK_PROVIDERS=false to use real COS document storage.
# How to find credentials:
#   IBM Cloud → Resource list → Cloud Object Storage instance → Service credentials
# Endpoint:
#   IBM Cloud → COS instance → Buckets → <bucket> → Configuration → Endpoints
# Resource Instance ID:
#   IBM Cloud → COS instance → Service credentials → resource_instance_id
IBM_COS_API_KEY=
IBM_COS_RESOURCE_INSTANCE_ID=
IBM_COS_ENDPOINT=
IBM_COS_BUCKET_NAME=
IBM_COS_AUTH_ENDPOINT=https://iam.cloud.ibm.com/identity/token

# Maximum document upload size in bytes (default: 20971520 = 20 MB)
MAX_UPLOAD_BYTES=20971520

# ── RAG Pipeline (Phase 8) ────────────────────────────────────────────────────
# Embedding model ID for IBM watsonx.ai.
# Verify availability in your region/project before setting.
# Common IBM embedding models: ibm/slate-125m-english-rtrvr, ibm/slate-30m-english-rtrvr
# Required when USE_MOCK_PROVIDERS=false for RAG operations.
WATSONX_EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr

# Chunk size in characters (approximate — not exact token count)
# Default 800 chars ≈ 150-200 tokens for Slate 125M embedding model
RAG_CHUNK_SIZE=800

# Overlap between adjacent chunks in characters
RAG_CHUNK_OVERLAP=100

# Number of top chunks to retrieve per query
RAG_TOP_K=5

# Minimum cosine similarity score threshold (0.0 – 1.0)
# Chunks below this score are not included in context
RAG_MIN_SCORE=0.30

# Maximum chunks to embed per API request (respect provider input limits)
RAG_EMBEDDING_BATCH_SIZE=10

# Processing version tag — increment to force reindexing on config change
RAG_PROCESSING_VERSION=1

# ── Weather Agent (Phase 10) — Open-Meteo (no API key required) ──────────────
# Open-Meteo is a free, open-source weather API — no authentication required.
# Only set these if you need to point to a self-hosted or alternative instance.
WEATHER_API_URL=https://api.open-meteo.com/v1
WEATHER_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1

# Number of forecast days to retrieve (1–16; default 7)
WEATHER_FORECAST_DAYS=7

# In-memory cache TTL in seconds (default 900 = 15 minutes)
# Cached results within this window avoid repeated API calls for the same location.
WEATHER_CACHE_TTL_SECONDS=900

# HTTP request timeout in milliseconds (default 10000 = 10 seconds)
WEATHER_REQUEST_TIMEOUT_MS=10000


# phase 11
MARKET_API_URL=https://api.data.gov.in/resource
MARKET_API_KEY=
MARKET_API_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

MARKET_CACHE_TTL_SECONDS=1800
MARKET_REQUEST_TIMEOUT_MS=10000
MARKET_MAX_RECORDS=100

# ── Government Scheme Discovery Agent (Phase 12) ──────────────────────────────
# No external API key required — scheme data comes from MongoDB curated records
# and the existing RAG pipeline (IBM COS + watsonx.ai embeddings).

# Days since lastVerifiedAt before a stale-verification warning is added.
# Scheme rules change; older records should be re-confirmed with official sources.
SCHEME_VERIFICATION_STALE_DAYS=90

# Maximum scheme records to return per discovery/search request.
SCHEME_SEARCH_LIMIT=10

# Number of document chunks to retrieve from RAG for detailed scheme questions.
SCHEME_RAG_TOP_K=5

# ── Crop Recommendation Agent (Phase 13) ──────────────────────────────────────
# No external API key required — crop data uses in-memory verified profiles
# from ICAR/ICRISAT curated seed data.

# Maximum number of candidate crops to evaluate before scoring (default: 15)
CROP_CANDIDATE_LIMIT=15

# Number of top crops to return in recommendation results (default: 3)
CROP_RESULT_LIMIT=3

# Number of RAG knowledge chunks to retrieve per crop during evidence collection
CROP_RAG_TOP_K=3

# Scoring engine version tag — increment to document configuration changes
CROP_SCORING_VERSION=1.0.0

# Scoring factor weights (must collectively represent relative importance)
# Change these to tune how the recommendation engine weighs different factors.
# Season fit is most critical; scheme support is a bonus signal.
CROP_WEIGHT_SEASON_FIT=0.22
CROP_WEIGHT_SOIL_FIT=0.20
CROP_WEIGHT_WATER_FIT=0.20
CROP_WEIGHT_LOCATION_FIT=0.10
CROP_WEIGHT_WEATHER_FIT=0.10
CROP_WEIGHT_ROTATION_FIT=0.08
CROP_WEIGHT_MARKET_EVIDENCE=0.06
CROP_WEIGHT_KNOWLEDGE_FIT=0.03
CROP_WEIGHT_SCHEME_SUPPORT=0.01

# ── Phase 14A: Multilingual Text Interface ────────────────────────────────────

# Minimum number of Hinglish keyword matches required to classify a message
# as Hinglish (hi-Latn). Lower = more sensitive. Default: 2
LANG_DETECT_HINGLISH_THRESHOLD=2

# Use the configured LLM as a Tier 3 fallback for language detection when
# Unicode and Hinglish heuristics are ambiguous.
# true  = LLM fallback enabled (uses existing AI provider — no extra credentials)
# false = heuristics only (synchronous, faster, works offline)
LANG_DETECT_USE_LLM_FALLBACK=true

# ── Phase 14B: IBM Speech to Text (Voice Input) ───────────────────────────────
# Required only when USE_MOCK_PROVIDERS=false and voice input is enabled.
# IBM Cloud Speech to Text — https://cloud.ibm.com/catalog/services/speech-to-text

IBM_STT_API_KEY=
IBM_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com
IBM_IAM_URL=https://iam.cloud.ibm.com/identity/token

# IBM STT model — selects the acoustic and language model.
# en-US_BroadbandModel = English (US), 16kHz+ — best for wideband audio
# hi-IN_Telephony      = Hindi (India) — switched automatically when language=hi
IBM_STT_MODEL=en-US_BroadbandModel

# Maximum audio upload size in bytes (default: 5 MB = 5242880)
VOICE_MAX_BYTES=5242880


# ── Phase 14B: IBM Text to Speech (Voice Output) ─────────────────────────────
# Required only when USE_MOCK_PROVIDERS=false and voice output is enabled.
# IBM Cloud Text to Speech — https://cloud.ibm.com/catalog/services/text-to-speech

IBM_TTS_API_KEY=
IBM_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com

# Default voice for English responses
IBM_TTS_VOICE=en-US_AllisonV3Voice

# Per-language voice overrides
# These voices require Standard or Premium IBM TTS plan.
# If your plan doesn't include them, set to en-US_AllisonV3Voice as a fallback.
IBM_TTS_VOICE_HI=hi-IN_EelaVoice
IBM_TTS_VOICE_HI_LATN=en-US_AllisonV3Voice
IBM_TTS_VOICE_PA=en-US_AllisonV3Voice

# Maximum text length in bytes before truncation (IBM TTS limit: 5000 bytes)
TTS_MAX_TEXT_BYTES=5000


# ── Phase 15D: Image Upload (Chat Image) ─────────────────────────────────────
# Chat-level image uploads (e.g. disease photo).
# Uses IBM COS (same credentials as Phase 7 IBM_COS_* above) — no new keys needed.

# Maximum image upload size in bytes for a single chat message (default: 5 MB)
MAX_IMAGE_BYTES=5242880

# Comma-separated list of allowed MIME types for uploaded images
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp


# ── Phase 16A: Farmer Memory Foundation ──────────────────────────────────────
# No external credentials required — memory is stored in MongoDB FarmerProfile.

# Maximum items in each memory array (history, facts, recommendations, warnings)
# Prevents unbounded growth. Oldest items are dropped when the limit is reached.
MEMORY_MAX_ARRAY_SIZE=15

# Number of recent conversation messages passed to IBM Granite for summarization.
# Lower = faster / fewer tokens. Minimum useful value is 2.
MEMORY_SUMMARIZATION_MIN_MESSAGES=4


# ── Phase 16B: Context Injection ─────────────────────────────────────────────
# Controls how much historical memory is injected into agent prompts.

# Maximum memory items injected into a single agent prompt.
# Higher = richer context but more tokens consumed.
CONTEXT_MAX_ITEMS=5

# TTL (days) for each memory category before items are excluded from context.
# Weather alerts older than 7 days are not useful for current decisions.
CONTEXT_WEATHER_TTL_DAYS=7
# Market prices from more than 30 days ago are stale.
CONTEXT_MARKET_TTL_DAYS=30
# Disease history can be relevant for up to a full crop cycle (365 days).
CONTEXT_DISEASE_TTL_DAYS=365
# Crop recommendations align with a ~180 day growing season.
CONTEXT_CROP_TTL_DAYS=180


# ── Phase 16D: Smart Follow-up and Personalized Assistance ───────────────────
# Controls thresholds for deterministic follow-up rule generation.
# No external credentials required.

# Rain probability (%) above which a "Delay irrigation" follow-up is triggered.
FOLLOWUP_WEATHER_RAIN_THRESHOLD=80

# Air temperature (°C) above which a heat-stress warning follow-up is triggered.
FOLLOWUP_WEATHER_HIGH_TEMP_THRESHOLD=38

# Disease diagnostic confidence (0.0–1.0) above which a Critical follow-up fires.
# Default 0.80 = 80%. Set higher (e.g. 0.90) to reduce false positives.
FOLLOWUP_DISEASE_CONFIDENCE_THRESHOLD=0.80

# Price movement (%) above which a price-spike follow-up is triggered.
FOLLOWUP_MARKET_PRICE_SPIKE_THRESHOLD=10

# Price movement (%) below which a price-drop follow-up is triggered.
FOLLOWUP_MARKET_PRICE_DROP_THRESHOLD=10

# Maximum number of follow-up suggestions returned to the frontend per request.
# Keep this low (3–5) to avoid overwhelming the user.
FOLLOWUP_MAX_SUGGESTIONS=4

# Number of days of recommendation history to include in the assistant panel.
FOLLOWUP_HISTORY_DAYS=30

# Maximum number of past recommendations to show.
FOLLOWUP_HISTORY_LIMIT=10