# ── AgroGenie AI — Production Environment Variables ───────────────────────────
# Copy this file to server/.env and fill in all required values.
# NEVER commit server/.env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=https://<your-code-engine-app>.us-south.codeengine.appdomain.cloud

# ── Provider Mode ─────────────────────────────────────────────────────────────
# Set false for production to use real IBM services
USE_MOCK_PROVIDERS=false
ENABLE_DEMO_MODE=false

# ── Logging ───────────────────────────────────────────────────────────────────
# info = standard production logging (JSON format)
# warn = reduced noise (errors + warnings only)
LOG_LEVEL=info

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_PROD=200

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add any additional trusted origins (comma-separated)
CORS_EXTRA_ORIGINS=

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get from: Atlas Dashboard → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=agrogenie

# ── IBM watsonx.ai ────────────────────────────────────────────────────────────
# Get API key: IBM Cloud → IAM → API Keys
# Get Project ID: IBM Cloud → watsonx.ai → Manage → Projects
WATSONX_API_KEY=<your-watsonx-api-key>
WATSONX_PROJECT_ID=<your-watsonx-project-id>
WATSONX_URL=https://us-south.ml.cloud.ibm.com
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ── IBM watsonx.ai Embeddings ─────────────────────────────────────────────────
# Verify model availability in your region/project
WATSONX_EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr

# ── IBM Cloud Object Storage ──────────────────────────────────────────────────
# Get from: IBM Cloud → Resource List → Cloud Object Storage → Service Credentials
IBM_COS_API_KEY=<your-cos-api-key>
IBM_COS_RESOURCE_INSTANCE_ID=crn:v1:bluemix:public:cloud-object-storage:global:...
IBM_COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
IBM_COS_BUCKET_NAME=<your-bucket-name>
IBM_COS_AUTH_ENDPOINT=https://iam.cloud.ibm.com/identity/token

# ── IBM Speech to Text ────────────────────────────────────────────────────────
# Get from: IBM Cloud → Speech to Text → Service Credentials
IBM_STT_API_KEY=<your-stt-api-key>
IBM_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com
IBM_IAM_URL=https://iam.cloud.ibm.com/identity/token
IBM_STT_MODEL=en-US_BroadbandModel
VOICE_MAX_BYTES=5242880

# ── IBM Text to Speech ────────────────────────────────────────────────────────
# Get from: IBM Cloud → Text to Speech → Service Credentials
IBM_TTS_API_KEY=<your-tts-api-key>
IBM_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com
IBM_TTS_VOICE=en-US_AllisonV3Voice
IBM_TTS_VOICE_HI=hi-IN_EelaVoice
IBM_TTS_VOICE_HI_LATN=en-US_AllisonV3Voice
IBM_TTS_VOICE_PA=en-US_AllisonV3Voice
TTS_MAX_TEXT_BYTES=5000

# ── Market Data (data.gov.in) ─────────────────────────────────────────────────
# Register at: https://data.gov.in/developers
MARKET_API_URL=https://api.data.gov.in/resource
MARKET_API_KEY=<your-data-gov-in-api-key>
MARKET_API_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070
MARKET_CACHE_TTL_SECONDS=1800
MARKET_REQUEST_TIMEOUT_MS=10000
MARKET_MAX_RECORDS=100

# ── Weather (Open-Meteo — no key required) ────────────────────────────────────
WEATHER_API_URL=https://api.open-meteo.com/v1
WEATHER_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1
WEATHER_FORECAST_DAYS=7
WEATHER_CACHE_TTL_SECONDS=900
WEATHER_REQUEST_TIMEOUT_MS=10000

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=20971520
MAX_IMAGE_BYTES=5242880
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ── RAG Pipeline ─────────────────────────────────────────────────────────────
WATSONX_EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_MIN_SCORE=0.30
RAG_EMBEDDING_BATCH_SIZE=10
RAG_PROCESSING_VERSION=1

# ── Government Schemes ────────────────────────────────────────────────────────
SCHEME_VERIFICATION_STALE_DAYS=90
SCHEME_SEARCH_LIMIT=10
SCHEME_RAG_TOP_K=5

# ── Crop Recommendation ───────────────────────────────────────────────────────
CROP_CANDIDATE_LIMIT=15
CROP_RESULT_LIMIT=3
CROP_RAG_TOP_K=3
CROP_SCORING_VERSION=1.0.0

# ── Multilingual ─────────────────────────────────────────────────────────────
LANG_DETECT_HINGLISH_THRESHOLD=2
LANG_DETECT_USE_LLM_FALLBACK=true

# ── Farmer Memory ─────────────────────────────────────────────────────────────
MEMORY_MAX_ARRAY_SIZE=15
MEMORY_SUMMARIZATION_MIN_MESSAGES=4
CONTEXT_MAX_ITEMS=5
CONTEXT_WEATHER_TTL_DAYS=7
CONTEXT_MARKET_TTL_DAYS=30
CONTEXT_DISEASE_TTL_DAYS=365
CONTEXT_CROP_TTL_DAYS=180

# ── Follow-up Engine ──────────────────────────────────────────────────────────
FOLLOWUP_WEATHER_RAIN_THRESHOLD=80
FOLLOWUP_WEATHER_HIGH_TEMP_THRESHOLD=38
FOLLOWUP_DISEASE_CONFIDENCE_THRESHOLD=0.80
FOLLOWUP_MARKET_PRICE_SPIKE_THRESHOLD=10
FOLLOWUP_MARKET_PRICE_DROP_THRESHOLD=10
FOLLOWUP_MAX_SUGGESTIONS=4
FOLLOWUP_HISTORY_DAYS=30
FOLLOWUP_HISTORY_LIMIT=10
