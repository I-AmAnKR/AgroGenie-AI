{
  "name": "agrogenie-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client",
    "start:prod": "npm run start:prod --workspace=server",
    "lint": "npm run lint --workspace=client",
    "lint:server": "npm run lint --workspace=server",
    "test": "npm run test --workspace=server && npm run test --workspace=client",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
